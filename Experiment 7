5. Control Constructs
a)If Statement-Check if a number is positive
#!/bin/bash
num=10
if [ $num -gt 0 ]; then
echo "$num is a positive number"
fi
mca@MCA51:~/mca/suhaa s1/netlab$ ./file2.sh
10 is a positive number

b)If–Else Statement-To check whether a given number is greater than 5
#!/bin/bash
num=3
if [ $num -gt 5 ]; then
     echo "Greater than 5"
else
     echo "Less than or equal to 5"
fi
mca@MCA51:~/mca/suhaa s1/netlab$ ./file2.sh
Less than or equal to 5
c)Check even or odd
#!/bin/bash
num=7
if (( num % 2 == 0 ))
then
    echo "$num is Even"
else
    echo "$num is Odd"
fi

mca@MCA51:~/mca/suhaa s1/netlab$ ./file2.sh
7 is Odd
d)
if-elif-else Statement
#!/bin/bash
marks=95
if [ $marks -ge 90 ]
then
    echo "Grade: A"
elif [ $marks -ge 75 ]
then
    echo "Grade: B"
elif [ $marks -ge 50 ]
then
    echo "Grade: C"
else
    echo "Grade: Fail"
fi
mca@MCA51:~/mca/suhaa s1/netlab$ ./file2.sh
Grade: A

