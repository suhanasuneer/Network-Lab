Basic Add & Subtract
#!/bin/bash
add() {
    result=$(( $1 + $2 ))
    echo "Addition of $1 + $2 = $result"
}

subtract() {
    result=$(( $1 - $2 ))
    echo "Subtraction of $1 - $2 = $result"
}

add 20 10
subtract 20 10

mca@MCA51:~/mca/suhaa s1/netlab$ ./file2.sh
Addition of 20 + 10 = 30
Subtraction of 20 - 10 = 10

